# Richard -- claude-code-telegram safety-net agent config
# Generated by clawdee-install v3.0.0

# Telegram
TELEGRAM_BOT_TOKEN={{RICHARD_BOT_TOKEN}}
TELEGRAM_BOT_USERNAME={{RICHARD_BOT_USERNAME}}

# Auth: empty API key + USE_SDK=true -> Claude CLI OAuth from ~/.claude/
USE_SDK=true
ANTHROPIC_API_KEY=
CLAUDE_CLI_PATH=

# Access control
ALLOWED_USERS={{TG_USER_ID}}
APPROVED_DIRECTORY=/home/{{USER}}

# Hardening (audit C3 fix)
ENVIRONMENT=production
DEVELOPMENT_MODE=false
DISABLE_TOOL_VALIDATION=false
ENABLE_MCP=false

# Tool allowlist (audit C3 fix -- conservative default)
CLAUDE_ALLOWED_TOOLS=Read,Write,Edit,Bash,Glob,Grep,LS,Task,WebFetch,WebSearch
